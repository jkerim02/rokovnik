# ---- Node / package managers ----
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ---- Expo ----
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# ---- Native build artifacts ----
android/
ios/
*.orig.*
*.apk
*.aab
*.ipa

# ---- Metro ----
.metro-health-check*

# ---- TypeScript ----
*.tsbuildinfo

# ---- EAS / Expo credentials & secrets ----
# Keep eas.json (config) but never commit secrets/credentials
credentials.json
google-services.json
GoogleService-Info.plist

# ---- Environment variables ----
.env
.env.*
!.env.example

# ---- Supabase (Phase 2) ----
supabase/.branches
supabase/.temp
**/supabase/.env

# ---- SQLite / local databases (local-only data, never commit) ----
*.db
*.db-journal
*.sqlite
*.sqlite3

# ---- Logs ----
*.log
logs/

# ---- Private / local-only docs (kept on disk, never pushed) ----
usputnik-arhitektura.md

# ---- Editor / OS ----
.DS_Store
Thumbs.db
*.swp
*~

# ---- Keep VSCode workspace settings, ignore user-local noise ----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
